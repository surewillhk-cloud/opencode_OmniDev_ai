{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "description": "Workflow orchestration - v5.2: 主动测试触发、角色强化、质量门禁",
      "mode": "primary",
      "tools": {
        "read": true,
        "task": true,
        "grep": true,
        "glob": true,
        "skill": true
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "product-manager": {
      "description": "Requirements analysis - v5.2: 角色强化、需求澄清标准",
      "mode": "subagent",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "grep": true,
        "glob": true,
        "skill": true
      }
    },
    "ui-designer": {
      "description": "UI Design - v5.2: 状态覆盖标准、响应式验证",
      "mode": "subagent",
      "tools": {
        "read": true,
        "write": true,
        "grep": true,
        "glob": true,
        "skill": true
      }
    },
    "fullstack-dev": {
      "description": "Full-stack development - v5.2: API冒烟测试、开发伴随测试",
      "mode": "subagent",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "npm run*": "allow",
          "npm install*": "allow",
          "npx*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "curl*": "allow",
          "node*": "allow"
        }
      }
    },
    "qa-tester": {
      "description": "Testing & Validation - v5.2: 5-Why根因分析、API冒烟测试、主动测试",
      "mode": "subagent",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "grep": true,
        "glob": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "npm run*": "allow",
          "npm install*": "allow",
          "npx*": "allow",
          "curl*": "allow",
          "node*": "allow",
          "git status*": "allow",
          "git diff*": "allow"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "edit": {
      "pattern": "AGENTS.md",
      "action": "deny"
    },
    "edit": {
      "pattern": "opencode.json",
      "action": "deny"
    },
    "edit": {
      "pattern": "QUICKSTART.md",
      "action": "deny"
    },
    "edit": {
      "pattern": "CHANGELOG.md",
      "action": "deny"
    },
    "edit": {
      "pattern": ".opencode/**",
      "action": "deny"
    },
    "edit": {
      "pattern": "scripts/**",
      "action": "deny"
    },
    "edit": {
      "pattern": ".env",
      "action": "deny"
    },
    "write": {
      "pattern": "AGENTS.md",
      "action": "deny"
    },
    "write": {
      "pattern": "opencode.json",
      "action": "deny"
    },
    "write": {
      "pattern": "QUICKSTART.md",
      "action": "deny"
    },
    "write": {
      "pattern": "CHANGELOG.md",
      "action": "deny"
    },
    "write": {
      "pattern": ".opencode/**",
      "action": "deny"
    },
    "write": {
      "pattern": "scripts/**",
      "action": "deny"
    },
    "write": {
      "pattern": ".env",
      "action": "deny"
    }
  }
}
